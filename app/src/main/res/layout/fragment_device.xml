<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5EFE3"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#20352B"
            app:cardCornerRadius="28dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Part 2"
                    android:textColor="#D5DFC8"
                    android:textSize="14sp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mobile Info &amp; Spec"
                    android:textColor="#F7F2EC"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Device Identity Container -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#FDF8F1"
            app:cardCornerRadius="24dp">
            <LinearLayout
                android:id="@+id/ll_device_identity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Device Identity"
                    android:textSize="20sp"
                    android:textColor="#20352B" />
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E7DEC8"
                    android:layout_marginVertical="10dp"/>
                <Button
                    android:id="@+id/btn_request_phone_state"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Allow Phone State Access"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Software & Hardware Container -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#FDF8F1"
            app:cardCornerRadius="24dp">
            <LinearLayout
                android:id="@+id/ll_software_hardware"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Software &amp; Hardware"
                    android:textSize="20sp"
                    android:textColor="#20352B" />
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E7DEC8"
                    android:layout_marginVertical="10dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Battery & Network Container -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#FDF8F1"
            app:cardCornerRadius="24dp">
            <LinearLayout
                android:id="@+id/ll_battery_network"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Battery &amp; Network"
                    android:textSize="20sp"
                    android:textColor="#20352B" />
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E7DEC8"
                    android:layout_marginVertical="10dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
